APP_NAME=HSE Safety Compliance Intelligence API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://hse_user:hse_password@localhost:3306/hse
JWT_ISSUER=hse-platform
JWT_AUDIENCE=hse-users
JWT_SECRET=replace-with-azure-key-vault-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=evidence
AZURE_KEY_VAULT_URL=
