APP_NAME=HSE Safety Compliance Intelligence API
APP_ENV=local
DEBUG=true
API_V1_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://root:password@localhost:3306/hse
JWT_ISSUER=hse-platform
JWT_AUDIENCE=hse-users
JWT_SECRET=replace-with-azure-key-vault-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:5173"]
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=evidence
AZURE_KEY_VAULT_URL=

# ── AI Model Providers ──────────────────────────────────────────────────────
# Azure OpenAI (Default)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2025-01-01-preview

# Anthropic Claude — direct API or Azure AI Foundry hosted
# For Azure AI Foundry: set ANTHROPIC_BASE_URL to your Cognitive Services endpoint
# e.g. https://<resource>.cognitiveservices.azure.com/anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Email delivery ──────────────────────────────────────────────────────────
# Option 1: SendGrid (takes priority when set)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@hse-platform.com
SENDGRID_FROM_NAME=HSE Platform

# Option 2: SMTP fallback (used when SENDGRID_API_KEY is blank)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=HSE Platform
