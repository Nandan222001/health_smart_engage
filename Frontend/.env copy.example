# API Configuration
VITE_API_URL=https://localhost:8000/api

# Firebase Configuration — copy from your Firebase console project settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Set VITE_ENABLE_DEV_TEST_ACCOUNTS=true in .env.local for local dev testing only — never in production
VITE_ENABLE_DEV_TEST_ACCOUNTS=false
# Comma-separated list of product admin emails that bypass onboarding checks
VITE_PRODUCT_ADMIN_EMAILS=
# Enable dev product admin bypass (only active when NODE_ENV=development)
VITE_ENABLE_DEV_PRODUCT_ADMIN_FALLBACK=true
# Enable hardcoded superadmin login in production — keep false unless explicitly required
VITE_ENABLE_PROD_SUPERADMIN_HARDCODED_LOGIN=false

# Dev Test Account Credentials (only used when VITE_ENABLE_DEV_TEST_ACCOUNTS=true)
# Set these in .env.local — never commit real passwords
VITE_DEV_ADMIN_EMAIL=
VITE_DEV_ADMIN_PASSWORD=
VITE_DEV_SUPER_ADMIN_EMAIL=
VITE_DEV_SUPER_ADMIN_PASSWORD=
VITE_DEV_SUPER_ADMIN_PASSWORD_ALT=
VITE_DEV_INSPECTOR_EMAIL=
VITE_DEV_INSPECTOR_PASSWORD=
VITE_DEV_ENGINEER_EMAIL=
VITE_DEV_ENGINEER_PASSWORD=
VITE_DEV_WORKER_EMAIL=
VITE_DEV_WORKER_PASSWORD=
